# Copia este archivo a `backend/.env` y rellena con tus valores
# También puedes definir variables en `.env` en la raíz del proyecto.

# === BASE DE DATOS ===
# Para desarrollo local con XAMPP (por defecto):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=spotmap
DB_USERNAME=root
DB_PASSWORD=

# Para PlanetScale (descomenta y cambia los valores):
# DB_HOST=us-east.connect.psdb.cloud
# DB_PORT=3306
# DB_DATABASE=spotmap
# DB_USERNAME=pscale_user_xxxx
# DB_PASSWORD=pscale_pwd_xxxx

# === ENTORNO ===
# Valores: development, production, staging
ENV=development

# === DEBUG ===
# true = logs detallados, false = logs mínimos
DEBUG=true

# === LOGGING ===
# Niveles: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# === SEGURIDAD ===
# Habilitar rate limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# === CORS ===
# Dominios permitidos (separados por comas)
#CORS_ORIGINS=http://localhost,http://localhost:3000

# === API ===
# Versión de API (informativo)
API_VERSION=1.0.0
# Override admin por correo (coma separada, opcional)
# ADMIN_EMAILS=admin@spotmap.local
# Solo para desarrollo: permitir fallback JWT sin firma (NO usar en producción)
ALLOW_INSECURE_JWT_FALLBACK=false
# Mostrar datos extendidos en /api/status (recomendado false en producción)
STATUS_VERBOSE=false
# Token opcional para proteger /api/status (enviar en header X-Status-Token)
# STATUS_TOKEN=change-me

# Endpoints de diagnóstico (/ping-db, /db-info)
DIAGNOSTICS_ENABLED=false
# DIAGNOSTIC_TOKEN=change-me

# === SUPABASE (opcional, recomendado en integración real) ===
# Si están definidas, el backend usará Supabase en lugar de MySQL local
# Debe ser la URL base del proyecto, sin /rest/v1
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# Recomendado para validar firma JWT en fallback local
SUPABASE_JWT_SECRET=

